-- ================================================================
-- IMDB Top 1000 Movies Analysis
-- Table: imdb_1000
-- Columns: star_rating, title, content_rating, genre, duration, actors_list
-- ================================================================


-- 1. Which genre has the most high-rated movies (rating >= 8.0)
SELECT 
    genre,
    COUNT(*) AS high_rated_count
FROM imdb_rating.imdb_1000
WHERE star_rating >= 8.0
GROUP BY genre
ORDER BY high_rated_count DESC
LIMIT 1;


-- 2. Which genre has the highest number of movies produced
SELECT 
    genre,
    COUNT(*) AS total_movies
FROM imdb_rating.imdb_1000
GROUP BY genre
ORDER BY total_movies DESC
LIMIT 1;


-- 3. Which genre has the longest duration of movies (by total duration)
SELECT 
    genre,
    SUM(duration) AS total_duration_mins
FROM imdb_rating.imdb_1000
GROUP BY genre
ORDER BY total_duration_mins DESC
LIMIT 1;


-- 4. Average duration of movies in each genre
SELECT 
    genre,
    ROUND(AVG(duration), 2) AS avg_duration_mins
FROM imdb_rating.imdb_1000
GROUP BY genre
ORDER BY avg_duration_mins DESC;


-- 5. Rank of Mystery genre among all genres by average rating
SELECT 
    genre_rank,
    genre,
    avg_rating
FROM (
    SELECT 
        genre,
        ROUND(AVG(star_rating), 2) AS avg_rating,
        RANK() OVER (ORDER BY AVG(star_rating) DESC) AS genre_rank
    FROM imdb_rating.imdb_1000
    GROUP BY genre
) ranked_genres
WHERE genre = 'Mystery';


-- 6. Top 10 movies based on average rating
SELECT 
    title,
    genre,
    star_rating
FROM imdb_rating.imdb_1000
ORDER BY star_rating DESC
LIMIT 10;


-- 7. Movies Brad Pitt worked in with rating > 8
SELECT 
    COUNT(*) AS brad_pitt_movies
FROM imdb_rating.imdb_1000
WHERE actors_list LIKE '%Brad Pitt%'
  AND star_rating > 8;


-- 8. PG-13 rated movies in the Crime genre
SELECT 
    COUNT(*) AS pg13_crime_movies
FROM imdb_rating.imdb_1000
WHERE content_rating = 'PG-13'
  AND genre = 'Crime';


-- 9. How many Comedy movies made it to the top 10 by average rating
SELECT 
    COUNT(*) AS comedy_in_top10
FROM (
    SELECT 
        title,
        genre,
        star_rating
    FROM imdb_rating.imdb_1000
    ORDER BY star_rating DESC
    LIMIT 10
) top10
WHERE genre = 'Comedy';


-- 10. Best movie (highest rated) from each genre
SELECT 
    genre,
    title,
    star_rating
FROM (
    SELECT 
        genre,
        title,
        star_rating,
        RANK() OVER (PARTITION BY genre ORDER BY star_rating DESC) AS rnk
    FROM imdb_rating.imdb_1000
) ranked
WHERE rnk = 1
ORDER BY star_rating DESC;
